#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

# Rebuild the default OG image if the site header component changed
if git diff --cached --name-only | grep -q "lib/component.ex\|lib/layouts/og_image_layout.ex"; then
  echo "site_header changed — regenerating default OG image..."
  "$PROJECT_ROOT/scripts/gen_og_image.sh"
  git add "$PROJECT_ROOT/extra/images/og-default.png"
  echo "Default OG image updated and staged."
fi

# Rebuild coffee OG images if any coffee files changed
if git diff --cached --name-only | grep -q "^_coffee/"; then
  echo "Coffee files changed — regenerating coffee OG images..."
  cd "$PROJECT_ROOT" && mix gen_coffee_og_images
  git add "$PROJECT_ROOT/extra/images/og/coffee/"
  echo "Coffee OG images updated and staged."
fi
